        function alternarDetalhes(icon) {

            var id = icon.getAttribute('data-ID');

            if (!id || isNaN(id)) {
                console.warn('Código do projeto filho inválido ou não numérico:', id);
                return;
            }

            // Atualiza o campo hidden do ASP.NET
            var hdn = document.getElementById('ctl00_ContentPlaceHolder1_ProjetosUserControl1_InformacoesProjetoUserControl_hdnProjetoExpandido');
            if (hdn) {
                hdn.value = id;
            }

            var linhaPrincipal = icon.closest('tr');
            var linhaDetalhes = linhaPrincipal.nextElementSibling;

            if (!linhaDetalhes || !linhaDetalhes.classList.contains('linha-detalhes')) {
                console.warn('Linha de detalhes não encontrada para esta linha principal.');
                return;
            }

            var icone = icon.querySelector('i');
            var estaVisivel = linhaDetalhes.classList.contains('mostrar');

            // Fecha todas as outras linhas de detalhes
            document.querySelectorAll('.linha-detalhes').forEach(function (linha) {
                linha.classList.remove('mostrar');
            });

            // Atualiza todos os ícones
            document.querySelectorAll('.linha-principal i').forEach(function (i) {
                i.classList.remove('fa-caret-down');
                i.classList.add('fa-caret-right');
            });

            if (!estaVisivel) {
                linhaDetalhes.classList.add('mostrar');
                icone.classList.remove('fa-caret-right');
                icone.classList.add('fa-caret-down');
            }
        } function EsconderLoad(){ $('.loadImg').hide(); } $(function() { $( '#tab_controls' ).tabs(); });$(document).trigger('onConfiguracaoSistemaFusoHorarioJs', [ConfiguracaoSistemaFusoHorario]);var ConfiguracaoSistemaFusoHorario = {"CodConfigSistema":1,"FusoHorarioMinutosPedidoDiaria":-180,"FusoHorarioMinutosDespesaConvenio":-180,"FusoHorarioMinutosCambio":-180,"FusoHorarioMinutosArmazenamento":-180,"FusoHorarioMinutosAplicacao":-180};document.addEventListener('DOMContentLoaded', () => {setTimeout(function(){$(document).trigger('onConfiguracaoSistemaFusoHorarioJs', [ConfiguracaoSistemaFusoHorario]);},10);});//]]>
