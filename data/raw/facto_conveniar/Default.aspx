                <script>
                (() => {
                    const whitelistInput = /[a-zA-Z0-9À-ÿ\s.,;:?!'"_\-@#$%&*\/\\()[\]{}<>=+\|°^~´`¨]/g;
                    const whitelistTextarea = /[a-zA-Z0-9À-ÿ\s.,;:?!'"_\-@#$%&*\/\\()[\]{}<>=+\|°^~´`¨\n\r]/g;

                    function sanitize(str, regex) {
                        const matches = String(str || '').match(regex);
                        return matches ? matches.join('') : '';
                    }

                    function sanitizeElement(element) {
                        if (!element) return;
                        if (element.tagName === 'INPUT' || element.tagName === 'TEXTAREA') {
                            const regex = element.tagName === 'TEXTAREA' ? whitelistTextarea : whitelistInput;
                            const originalValue = element.value;
                            const cleanValue = sanitize(originalValue, regex);
                            if (cleanValue !== originalValue) {
                                const start = element.selectionStart;
                                element.value = cleanValue;
                                try {
                                    element.setSelectionRange(start, start);
                                } catch (e) { }
                            }
                        }
                    }

                    function sanitizeAllInputs() {
                        document.querySelectorAll('input, textarea').forEach(sanitizeElement);
                    }

                    document.addEventListener('input', e => {
                        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
                            sanitizeElement(e.target);
                        }
                    });

                    document.addEventListener('paste', e => {
                        const t = e.target;
                        if (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA') {
                            e.preventDefault();
                            const text = (e.clipboardData || window.clipboardData).getData('text');
                            const regex = t.tagName === 'TEXTAREA' ? whitelistTextarea : whitelistInput;
                            const clean = sanitize(text, regex);

                            if (document.execCommand) {
                                document.execCommand('insertText', false, clean);
                            } else {
                                const start = t.selectionStart;
                                const end = t.selectionEnd;
                                t.value = t.value.slice(0, start) + clean + t.value.slice(end);
                                t.setSelectionRange(start + clean.length, start + clean.length);
                            }
                        }
                    });

                    // Observer para mudanças programáticas
                    const observer = new MutationObserver(mutations => {
                        mutations.forEach(mutation => {
                            if (mutation.type === 'attributes' && mutation.attributeName === 'value') {
                                sanitizeElement(mutation.target);
                            }
                        });
                    });

                    function setupObservers() {
                        document.querySelectorAll('input, textarea').forEach(input => {
                            observer.observe(input, { attributes: true, attributeFilter: ['value'] });
                        });
                    }

                    // Hook para ASP.NET UpdatePanels
                    function hookAspNetEvents() {
                        if (typeof Sys !== 'undefined' && Sys.WebForms && Sys.WebForms.PageRequestManager) {
                            Sys.WebForms.PageRequestManager.getInstance().add_endRequest(() => {
                                setTimeout(() => {
                                    sanitizeAllInputs();
                                    setupObservers();
                                }, 50);
                            });
                        }
                    }

                    function initialize() {
                        sanitizeAllInputs();
                        setupObservers();
                        hookAspNetEvents();
                    }

                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', initialize);
                    } else {
                        initialize();
                    }

                    window.sanitizeInputs = sanitizeAllInputs;
                    window.sanitizeElement = sanitizeElement;
                })();
                </script>
