            $('tbody td', tableProjetos).css({ 'border': '0.5pt solid #bacde4' });
            $('.gridHeader th, .gridHeader td', tableProjetos).css({ 'background': '#4272B6', 'color': '#ffffff', 'font-weight': 'bold !important' });
