BURP_DATA_DIR=data
BURP_DB_PATH=data/burp.db
BURP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ajuste manual quando o teto anual mudar.
# Para anos novos, inclua explicitamente o valor vigente para evitar fallback.
BURP_TETO_CONSTITUCIONAL_BY_YEAR=2023=41650.92,2024=44008.52,2025=46366.19,2026=46366.19

# Fonte principal de salarios do recorte.
BURP_SOURCE_FEDERAL_ENABLED=true
BURP_FEDERAL_API_KEY=

# FAPES fica disponivel para refresh explicito na UI/API.
BURP_SOURCE_FAPES_ENABLED=true

# FACTO pode ser usado sob demanda na UI/API.
BURP_SOURCE_FACTO_ENABLED=true
BURP_FACTO_DAYS=30
BURP_FACTO_WINDOW_DAYS=31

# FEST pode ser usado sob demanda na UI/API.
BURP_SOURCE_FEST_ENABLED=true
BURP_FEST_DAYS=30
BURP_FEST_WINDOW_DAYS=31
